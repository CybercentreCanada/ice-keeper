<head>
  <style>
    body {
      margin: 0 !important;
      background-color: #fafafa;
      padding: 0;
      text-align: center;
      min-width: 640px;
      width: 100%;
      height: 100%;
      font-family: "Helvetica Neue", Helvetica, Arial, sans-serif;
    }
  </style>
</head>

<body style="text-align: center; width: 100%; height: 100%; margin: 0; padding: 0;" bgcolor="#fafafa">

  <table border="0" cellpadding="0" cellspacing="0" id="body"
    style="  text-align: center; width: 100%; margin: 0; padding: 0;" bgcolor="#fafafa">
    <tbody>

      <tr class="header">
        <td style=" font-size: 13px; line-height: 1.6; color: #5c5c5c; padding: 25px 0;">
          <img style="height: 120px;" src="https://hostname/branding/analyticalplatform/noswoosh-light.svg">
        </td>
      </tr>
      <tr class="header">
        <td style=" font-size: 13px; line-height: 1.6; color: #5c5c5c; padding: 25px 0;">
          <img style="height: 50px;" src="https://hostname/branding/analyticalplatform/name-light.svg">
        </td>
      </tr>
      <tr>
        <td>
          <table border="0" cellpadding="0" cellspacing="0" class="wrapper"
            style="width: 1640px; border-collapse: separate; border-spacing: 0; margin: 0 auto;">
            <tbody>
              <tr class="spacer">
                <td style=" height: 18px; font-size: 18px; line-height: 18px;">
                  &nbsp;
                </td>
              </tr>


              <tr>
                <td class="wrapper-cell"
                  style=" border-radius: 3px; overflow: hidden; padding: 18px 25px; border: 1px solid #ededed;"
                  align="left" bgcolor="#ffffff">
                  <table border="0" cellpadding="0" cellspacing="0" class="content"
                    style="width: 100%; border-collapse: separate; border-spacing: 0;">
                    <tbody>
                      <tr class="alert">
                        <td
                          style=" border-radius: 3px; font-size: 14px; line-height: 1.3; overflow: hidden; color: #ffffff; padding: 10px;"
                          align="center" bgcolor="#4765ee">
                          <table border="0" cellpadding="0" cellspacing="0" class="img"
                            style="border-collapse: collapse; margin: 0 auto;">
                            <tbody>
                              <tr>
                                <td style=" color: #ffffff;" align="center" valign="middle">
                                  <span>
                                    Tasks with recurring failures in ice-keeper automated table maintenance
                                  </span>
                                </td>
                              </tr>
                            </tbody>
                          </table>
                        </td>
                      </tr>
                      <tr class="spacer">
                        <td style=" height: 18px; font-size: 18px; line-height: 18px;">
                          &nbsp;
                        </td>
                      </tr>
                      <tr class="section">
                        <td style=" line-height: 1.4; overflow: hidden; padding: 0 15px;" align="center">
                          <table border="0" cellpadding="0" cellspacing="0" class="img"
                            style="border-collapse: collapse; width: 100%;">
                            <tbody>
                              <tr style="width: 100%;">
                                <td
                                  style=" font-size: 15px; line-height: 1.4; color: #626168; font-weight: 300; margin: 0; padding: 14px 0;"
                                  align="center">
                                  Full details are available in this Superset dashboard: <a
                                    href="https://hostname/superset/dashboard"
                                    style="display: inline-block; color: #3777b0; text-decoration: none;">ice-keeper
                                    table maintenance</a>. You can click on individual hyperlink in the results below.
                                  <p>
                                    {% if actual_num_failed_tasks > max_failed_tasks_in_preview %}
                                      Showing the first {{max_failed_tasks_in_preview}} failed tasks out of a total of {{actual_num_failed_tasks}}.
                                    {% else %}
                                      Showing {{actual_num_failed_tasks}} tasks failed.
                                    {% endif %} 
                                  </p>
                                </td>
                              </tr>
                            </tbody>
                          </table>
                        </td>
                      </tr>


                      <tr class="section">
                        <td style=" border-radius: 3px; overflow: hidden; padding: 0 15px; border: 1px solid #bdb8b8;">

                          <table border="0" cellpadding="0" cellspacing="0" class="info"
                            style="width: 100%; border-width: 1px; border-color: #ededed;"
                            align="left">
                            <tbody>
                              <tr>
                                <th
                                  style="text-align: left; font-size: 18px; color: #000000; font-weight: 500; margin: 10; padding: 14px 10;">
                                  Start Time
                                </th>
                                <th
                                  style="text-align: left; font-size: 18px; color: #000000; font-weight: 500; margin: 10; padding: 14px 10;">
                                  Table Name
                                </th>
                                <th
                                  style="text-align: left; font-size: 18px; color: #000000; font-weight: 500; margin: 10; padding: 14px 10;">
                                  Action
                                </th>
                                <th
                                  style="text-align: left; font-size: 18px; color: #000000; font-weight: 500; margin: 10; padding: 14px 10;">
                                  Statement
                                </th>
                                <th
                                  style="text-align: left; font-size: 18px; color: #000000; font-weight: 500; margin: 10; padding: 14px 10;">
                                  Status
                                </th>
                              </tr>

                              {% for row in rows %}
                              <tr>
                                <!-- start time -->
                                <td
                                  style="text-align: left; vertical-align: top; font-size: 15px; line-height: 1.4; color: #333333; font-weight: 300; margin: 10; padding: 14px 10; border-top-width: 1px; border-top-color: #bdb8b8; border-top-style: solid;">
                                 {{ row["start_time"] }}
                                </td>
                                <!-- full name -->
                                <td
                                  style="text-align: left; vertical-align: top; font-size: 15px; line-height: 1.4; color: #333333; font-weight: 300; margin: 10; padding: 14px 10; border-top-width: 1px; border-top-color: #bdb8b8; border-top-style: solid;">
                                 <a href="https://hostname/superset/dashboard">{{row["full_name"]}}</a>
                                </td>
                                <!-- action -->
                                <td
                                  style="text-align: left; vertical-align: top; font-size: 15px; line-height: 1.4; color: #333333; font-weight: 300; margin: 10; padding: 14px 10; border-top-width: 1px; border-top-color: #bdb8b8; border-top-style: solid;">
                                 {{ row["action"] }}
                                </td>
                                <!-- statement -->
                                <td
                                  style="white-space: pre-wrap; text-align: left; vertical-align: top; font-size: 15px; line-height: 1.4; color: #333333; font-weight: 300; margin: 10; padding: 14px 10; border-top-width: 1px; border-top-color: #bdb8b8; border-top-style: solid;">
                                  <pre><code>{{ row["sql_stm"].strip() }}</code></pre>
                                </td>
                                <!-- status -->
                                <td
                                  style="text-align: left; vertical-align: top; font-size: 15px; line-height: 1.4; color: #333333; font-weight: 300; margin: 10; padding: 14px 10; border-top-width: 1px; border-top-color: #bdb8b8; border-top-style: solid;">
                                  {{ row["status"] }}
                                </td>
                              </tr>
                              {% endfor %}
                            </tbody>
                          </table>
                        </td>
                      </tr>
                    </tbody>
                  </table>
                </td>
              </tr>
            </tbody>
          </table>
        </td>
      </tr>
    </tbody>
  </table>
</body>
</html>